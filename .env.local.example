# Copy this to .env.local and fill in the value.
#
# VITE_API_STAGE — the stage name of your API Gateway (REST API only).
# Check AWS Console → API Gateway → your API → Stages.
# Common values: prod, production, v1, dev
#
# Leave blank (or omit) if your gateway uses HTTP API v2 ($default stage).
VITE_API_STAGE=prod
